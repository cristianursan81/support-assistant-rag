# GestorIA — .dockerignore
# Keeps the image lean and prevents secrets from leaking into layers.

# Version control
.git/
.gitignore
.gitattributes

# Secrets — never bake into image
.env
.env.*
*.env
secrets/

# Python bytecode / caches
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Packaging / dist artifacts
*.egg-info/
dist/
build/
wheels/

# Tests & coverage (not needed at runtime)
tests/
test_*/
*_test.py
.pytest_cache/
.coverage
.coveragerc
htmlcov/

# Local DB files (persisted via Docker volume, not image layer)
*.db
*.sqlite
*.sqlite3
data/

# Docs & assets (not needed at runtime)
README.md
docs/
screenshots/
*.md

# Editor / OS noise
.DS_Store
.idea/
.vscode/
*.swp
*.swo
Thumbs.db

# CI / tooling config
.github/
.pre-commit-config.yaml
Makefile
