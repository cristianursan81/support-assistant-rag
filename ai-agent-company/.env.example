# ── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-api-key-here

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default — fine for MVP / single VPS):
DATABASE_URL=sqlite:///./gestoria.db
# PostgreSQL (recommended for production / multi-instance):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/gestoria?sslmode=require

# ── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate a strong secret — pick one:
#   openssl rand -base64 48
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=cambia-esto-por-una-cadena-aleatoria-larga

# ── Twilio WhatsApp ───────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=+34600000000
# Webhook URL (set in Twilio dashboard): https://tudominio.com/api/webhook/whatsapp

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tuempresa@gmail.com
SMTP_PASSWORD=tu-app-password
SMTP_FROM_NAME=GestorIA

# ── App ───────────────────────────────────────────────────────────────────────
BASE_URL=https://tudominio.com

# ── Observability / runtime ───────────────────────────────────────────────────
# LOG_LEVEL: debug | info | warning | error  (uvicorn + Python root logger)
LOG_LEVEL=info
# ENVIRONMENT: development | staging | production
ENVIRONMENT=production
# ALLOWED_ORIGINS: comma-separated list for CORS (use * only in dev)
ALLOWED_ORIGINS=https://tudominio.com

# ── Rate limiting (slowapi — foundation, activate in src/api.py) ──────────────
# SLOWAPI_RATE_LIMIT=100/minute
